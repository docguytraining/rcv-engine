{
  "name": "rcv-engine",
  "version": "1.0.1",
  "description": "Zero-dependency TypeScript library for tabulating ranked-choice elections (IRV and STV) with a complete, auditable result.",
  "keywords": [
    "rcv",
    "ranked-choice",
    "voting",
    "irv",
    "instant-runoff",
    "stv",
    "single-transferable-vote",
    "tabulation",
    "election",
    "audit"
  ],
  "license": "AGPL-3.0-only",
  "author": "Paul Pehrson",
  "repository": {
    "type": "git",
    "url": "https://github.com/docguytraining/rcv-engine.git"
  },
  "homepage": "https://github.com/docguytraining/rcv-engine#readme",
  "bugs": {
    "url": "https://github.com/docguytraining/rcv-engine/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src",
    "docs"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "fast-check": "^4.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
